{
  "name": "iteacher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "description": "Renders a root folder of teach workspaces as a multi-topic learning dashboard and runs its lessons end-to-end.",
  "bin": {
    "iteacher": "./dist/server/main.js"
  },
  "scripts": {
    "dev": "tsx src/server/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.10.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
